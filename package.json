{
  "name": "feathers-openweathermap",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "description": "An OpenWeatherMap Service for feathers.js applications",
  "author": "fratzinger",
  "homepage": "https://github.com/fratzinger/feathers-openweathermap",
  "repository": {
    "type": "git",
    "url": "https://github.com/fratzinger/feathers-openweathermap"
  },
  "keywords": [
    "feathers",
    "feathers.js",
    "feathers-plugin",
    "open-weather-map",
    "openweathermap"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "src/**",
    "dist/**"
  ],
  "scripts": {
    "build": "tsdown",
    "version": "pnpm run build",
    "lint": "eslint src/ test/",
    "test": "vitest run",
    "vitest": "vitest"
  },
  "dependencies": {
    "@feathersjs/errors": "^5.0.44"
  },
  "devDependencies": {
    "@feathers-community/eslint-config": "^0.0.10",
    "@feathersjs/feathers": "^5.0.44",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
