{
  "name": "feathers-openweathermap",
  "version": "1.0.0",
  "packageManager": "pnpm@10.12.4",
  "description": "An OpenWeatherMap Service for feathers.js applications",
  "author": "fratzinger",
  "homepage": "https://github.com/fratzinger/feathers-openweathermap",
  "repository": {
    "type": "git",
    "url": "https://github.com/fratzinger/feathers-openweathermap"
  },
  "keywords": [
    "feathers",
    "feathers.js",
    "feathers-plugin",
    "open-weather-map",
    "openweathermap"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "src/**",
    "dist/**"
  ],
  "scripts": {
    "build": "tsdown",
    "version": "pnpm run build",
    "lint": "eslint src/ test/",
    "test": "vitest run",
    "vitest": "vitest"
  },
  "dependencies": {
    "@feathersjs/errors": "^5.0.0"
  },
  "devDependencies": {
    "@feathers-community/eslint-config": "latest",
    "@feathersjs/feathers": "^5.0.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.0.1",
    "eslint": "^9.0.0",
    "tsdown": "latest",
    "typescript": "^5.0.0",
    "vitest": "latest"
  }
}
